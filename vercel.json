{
  "version": 2,
  "buildCommand": "echo 'No build required for static HTML/JS'",
  "outputDirectory": "frontend",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://gravito-backend-placeholder.koyeb.app/api/$1"
    },
    {
      "src": "/(.*)\\.([a-zA-Z0-9]+)$",
      "dest": "/$1.$2"
    },
    {
      "src": "^/recommendations/?$",
      "dest": "/recommendations.html"
    },
    {
      "src": "^/dashboard/?$",
      "dest": "/dashboard.html"
    },
    {
      "src": "^/saved-jobs/?$",
      "dest": "/saved-jobs.html"
    },
    {
      "src": "^/login/?$",
      "dest": "/login.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
